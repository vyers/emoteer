{
  "name": "@emoteer/theme",
  "version": "0.1.0",
  "description": "Design tokens, base CSS and Tailwind v4 preset for emoteer.",
  "license": "MIT",
  "author": "vyers <vyers.dev@gmail.com>",
  "homepage": "https://github.com/vyers/emoteer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyers/emoteer.git",
    "directory": "packages/theme"
  },
  "bugs": {
