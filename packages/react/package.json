{
  "name": "@emoteer/react",
  "version": "0.1.1",
  "description": "Headless and styled React components for emoji pickers, reactions, autocomplete and inputs.",
  "license": "MIT",
  "author": "vyers <vyers.dev@gmail.com>",
  "homepage": "https://emoteer.vyers.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vyers/emoteer.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/vyers/emoteer/issues"
  },
  "keywords": [
    "emoji",
    "emoteer",
    "react",
    "emoji-picker",
    "reactions",
    "emoji-autocomplete",
    "shortcodes",
    "zag"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "styles.css",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@emoteer/core": "workspace:*",
    "@emoteer/theme": "workspace:*",
    "@zag-js/react": "^1.39.0",
    "@zag-js/slider": "^1.39.0",
    "@zag-js/scroll-area": "^1.39.0",
    "@zag-js/popover": "^1.39.0",
    "@floating-ui/react": "^0.26.28",
    "@tanstack/react-virtual": "^3.13.5",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@emoteer/eslint-config": "workspace:*",
    "@emoteer/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
