{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@emoteer/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false,
    "allowJs": true,
    "checkJs": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.svelte.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
